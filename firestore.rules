rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isInventoryUser() {
      return signedIn() &&
        request.auth.token.email == "m_tropicolorsinv@hotmail.com";
    }

    function isAdminUser() {
      return signedIn() &&
        request.auth.token.email != "m_tropicolorsinv@hotmail.com";
    }

    function isOwnUser(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isTrackingStatus(status) {
      return status in [
        "pendiente",
        "pagado",
        "enviado",
        "entregado",
        "cancelado",
      ];
    }

    function isPublicTrackingCreate(trackingToken) {
      return request.resource.data.keys().hasOnly([
        "orderId",
        "orderNumber",
        "trackingToken",
        "status",
        "statusLabel",
        "description",
        "total",
        "currency",
        "paymentMethod",
        "paymentStatus",
        "items",
        "historial",
        "createdAt",
        "updatedAt",
      ]) &&
        request.resource.data.orderId is string &&
        request.resource.data.trackingToken == trackingToken &&
        isTrackingStatus(request.resource.data.status);
    }

    function isPublicTrackingLookupCreate(lookupId) {
      return request.resource.data.keys().hasOnly([
        "orderId",
        "orderNumber",
        "orderNumberLookup",
        "trackingToken",
        "createdAt",
        "updatedAt",
      ]) &&
        request.resource.data.orderId is string &&
        request.resource.data.orderNumber is string &&
        request.resource.data.orderNumberLookup == lookupId &&
        request.resource.data.trackingToken is string;
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdminUser();
    }

    match /references/{referenceId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdminUser();
    }

    match /orders/{orderId} {
      allow create: if true;
      allow read, update, delete: if isAdminUser();
    }

    match /order_tracking/{trackingToken} {
      allow get: if true;
      allow list: if false;
      allow create: if isAdminUser() || isPublicTrackingCreate(trackingToken);
      allow update, delete: if isAdminUser();
    }

    match /order_tracking_lookup/{lookupId} {
      allow get: if true;
      allow list: if false;
      allow create: if isAdminUser() || isPublicTrackingLookupCreate(lookupId);
      allow update, delete: if isAdminUser();
    }

    match /notifications/{notificationId} {
      allow create: if true;
      allow read, update, delete: if isAdminUser();
    }

    match /settings/home {
      allow read: if true;
      allow write: if isAdminUser();
    }

    match /users/{uid} {
      allow read, create, update: if isOwnUser(uid) || isAdminUser();
    }

    match /runtime/admin-panel-session {
      allow read, write: if isAdminUser();
    }

    match /productos/{productId} {
      allow read, write: if isInventoryUser() || isAdminUser();
    }

    match /movimientos/{movementId} {
      allow read, write: if isInventoryUser() || isAdminUser();
    }

    match /activity_logs/{logId} {
      allow create, read: if isAdminUser();
    }

    match /pedidos/{orderId} {
      allow read, write: if isAdminUser();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
